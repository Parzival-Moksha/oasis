{
  "mcpServers": {
    "parzival": {
      "type": "stdio",
      "command": "npx",
      "args": ["tsx", "src/mcp/index.ts"],
      "cwd": "../ae_parzival",
      "env": {}
    },
    "mission": {
      "type": "stdio",
      "command": "node",
      "args": ["tools/mission-mcp/index.js"],
      "env": {
        "OASIS_DB_PATH": "./prisma/data/oasis.db"
      }
    },
    "gamer": {
      "type": "stdio",
      "command": "node",
      "args": ["tools/visual-qa-mcp/index.js"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    }
  }
}
