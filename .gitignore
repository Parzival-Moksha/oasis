# Dependencies (root + all tool/plugin subdirs)
node_modules/
tools/*/node_modules/
openclaw-plugins/*/node_modules/

# Next.js build output
.next/
.next-staging/
out/
*.tsbuildinfo
.next-dev.log

# PM2 logs (relay + web)
logs/

# Local-only data (worlds, configs)
data/*.local.json

# Tooling caches and IDE configs
.cache/
.codex/

# Environment secrets
.env
.env.local
.env.production.local
.env.openclaw
admin-token.txt

# Runtime-generated GLBs (user conjurations)
public/conjured/*
