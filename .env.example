# ═══════════════════════════════════════════════════════════════
# OASIS — Environment Variables
# Copy this to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════════

# Database (SQLite — works out of the box, no setup needed)
DATABASE_URL="file:./data/oasis.db"

# Text-to-3D Providers (optional — conjure tab won't work without these)
MESHY_API_KEY=
TRIPO_API_KEY=

# LLM Procedural Geometry (optional — craft/terrain tools)
OPENROUTER_API_KEY=

# Image Generation (optional)
FAL_KEY=

# Voice Generation (optional)
ELEVENLABS_API_KEY=
