{
  "mcpServers": {
    "mission": {
      "command": "node",
      "args": [
        "tools/mission-mcp/index.js"
      ]
    },
    "gamer": {
      "command": "node",
      "args": [
        "tools/visual-qa-mcp/index.js"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "oasis": {
      "type": "streamable-http",
      "url": "http://localhost:4516/api/mcp/oasis"
    }
  }
}
