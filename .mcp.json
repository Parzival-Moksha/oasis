{
  "mcpServers": {
    "gamer": {
      "type": "stdio",
      "command": "node",
      "args": [
        "tools/visual-qa-mcp/index.js"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "oasis": {
      "type": "http",
      "url": "http://localhost:4516/api/mcp/oasis"
    },
    "mission": {
      "type": "stdio",
      "command": "node",
      "args": [
        "tools/mission-mcp/index.js"
      ],
      "env": {}
    }
  }
}
