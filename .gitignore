data/*.db-wal
prisma/data/*.db
prisma/data/*.db-journal
prisma/data/*.db-wal
prisma/data/*.db-shm
prisma/data/*.json
prisma/prisma/

# Avatar gallery thumbnails — tracked (tiny, needed for UI)
# public/avatars/gallery/thumbs/ is tracked

# User-uploaded avatars (runtime-generated)
public/avatars/*.glb
public/avatars/*.jpg
public/avatars/*.png
public/avatars/*.webp
public/avatars/*.gif

# Runtime-generated thumbnails
public/crafted-thumbs/*
!public/crafted-thumbs/.gitkeep
public/thumbs/*
# Avatar thumbnails — whitelisted
!public/thumbs/av_*.jpg

# Bulk source archives (blend/gltf zips — only extracted textures needed)
*.blend.zip
*.gltf.zip

# Animation libraries (large GLBs — not wired into catalog yet)
public/models/animations/

# Runtime data (per-instance, diverges between local dev and prod)
data/conjured-registry.json
data/scene-library.json
data/worlds/*.json
!data/worlds/forge-default.json
data/hermes-config.local.json
data/hermes-tunnel.local.json

# Backup / working copies of data files
data/*-full.json
data/*-showcase.json

# Server deploy script (lives on VPS only)
deploy.sh

# PM2 / logs
logs/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Dev specs (carbondir)
carbondir/

# Dev scripts
ralph.ps1

# Internal specs (not public documentation)
specs/

# Dev session artifacts
feb*.txt
tools/anorak-memory.md
/tmp-*.jpg
/tmp-*.png
/viewport-screenshot.png
public/viewport-screenshot.png

# Personal runtime state
data/anorak-pro*.local.json
data/hermes-*.local.json
public/screenshots/
__pycache__/
*.pyc

# Generated MCP config for claude-code route
.claude-code-mcp.json

# Test screenshots (CDP/Playwright — regenerated every run)
test-screenshots/
gamer-screenshots/

# Generated Merlin MCP configs + session data
.claude-code-mcp/
.merlin-mcp.json
src/app/api/merlin/sessions/

# Claude Code harness worktrees (runtime scratch for spawn_task chips)
.claude/worktrees/

